!(let $result2
    (collapse (frequency-pattern-miner &dbspace $x &cndpspace1 &conjspace1 5 0 True))
    (assertEqual $result2 ((supportOf (, (Inheritance $_100966 sodaDrinker) (Inheritance $_100966 ugly)) 5)
                            (supportOf (, (Inheritance $_101044 sodaDrinker) (Inheritance $_101044 woman)) 5) 
                            (supportOf (, (Inheritance $_101122 sodaDrinker) (Inheritance $_101122 man)) 5)
                            (supportOf (, (Inheritance $_101200 sodaDrinker) (Inheritance $_101200 human)) 10)
                            (supportOf (, (Inheritance $_101278 sodaDrinker) (Inheritance $_101278 $_101308)) 35)
                            (supportOf (, (Inheritance $_101356 ugly) (Inheritance $_101356 woman)) 5)
                            (supportOf (, (Inheritance $_101434 ugly) (Inheritance $_101434 man)) 5)
                            (supportOf (, (Inheritance $_101512 ugly) (Inheritance $_101512 human)) 10)
                            (supportOf (, (Inheritance $_101590 ugly) (Inheritance $_101590 $_101620)) 35)
                            (supportOf (, (Inheritance $_101668 woman) (Inheritance $_101668 human)) 10)
                            (supportOf (, (Inheritance $_101746 woman) (Inheritance $_101746 $_101776)) 30)
                            (supportOf (, (Inheritance $_101824 man) (Inheritance $_101824 human)) 10)
                            (supportOf (, (Inheritance $_101902 man) (Inheritance $_101902 $_101932)) 30)
                            (supportOf (, (Inheritance $_101980 human) (Inheritance $_101980 $_102010)) 60)
                            (supportOf (, (Inheritance $_102058 $_102064) (Inheritance $_102058 $_102088)) 190)
                            (supportOf (, (Inheritance $_102136 $_102142) (Inheritance $_102160 $_102142)) 800)))
)
!(let $result1
