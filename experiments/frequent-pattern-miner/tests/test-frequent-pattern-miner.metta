                            (supportOf (Inheritance $_250680 woman) 10)
                            (supportOf (Inheritance $_250722 man) 10)
                            (supportOf (Inheritance $_250764 human) 20)
                            (supportOf (Inheritance $_250806 $_250812) 60)))

 )
